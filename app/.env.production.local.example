# Copy to .env.production.local (git-ignored) and fill in real values.
# Only consulted for production builds (npm run build).

# Optional. SHA-256 hex digest of the PIN that unlocks the hidden
# researcher diagnostics screen (ResearchDiagnosticsScreen). Leave unset
# to disable the diagnostics PIN entry entirely.
# Generate with: node -e "console.log(require('crypto').createHash('sha256').update('YOUR_PIN').digest('hex'))"
VITE_RESEARCH_PIN_SHA256=
