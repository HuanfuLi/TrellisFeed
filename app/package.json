{
  "name": "app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "npm run test:main; npm run test:actions",
    "test:main": "node --test $(find tests -name '*.test.mjs' -not -name 'trellis-heal.test.mjs' -not -name 'trellis-prune.test.mjs' -not -name 'trellis-replant.test.mjs' -not -name 'graph-command-service.*.test.mjs')",
    "test:actions": "node --import ./tests/services/_actions-mock-loader.mjs --test tests/services/trellis-heal.test.mjs tests/services/trellis-prune.test.mjs tests/services/trellis-replant.test.mjs tests/services/graph-command-service.rename.test.mjs tests/services/graph-command-service.move.test.mjs tests/services/graph-command-service.delete.test.mjs tests/services/graph-command-service.merge.test.mjs tests/services/graph-command-service.detach.test.mjs tests/services/graph-command-service.prune.test.mjs tests/services/graph-command-service.undo.test.mjs tests/services/graph-command-service.integration.test.mjs tests/services/graph-command-service.reload-survival.test.mjs tests/services/graph-command-service.concurrency.test.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "^8.0.1",
    "@capacitor/android": "^8.3.3",
    "@capacitor/app": "^8.0.1",
    "@capacitor/cli": "^8.3.3",
    "@capacitor/core": "^8.3.3",
    "@capacitor/device": "^8.0.2",
    "@capacitor/haptics": "^8.0.1",
    "@capacitor/ios": "^8.3.3",
    "@capacitor/local-notifications": "^8.0.2",
    "@tailwindcss/vite": "^4.3.0",
    "capacitor-voice-recorder": "^7.0.6",
    "framer-motion": "^12.38.0",
    "fuse.js": "^7.3.0",
    "i18next": "^26.1.0",
    "katex": "^0.16.44",
    "lucide-react": "^0.575.0",
    "mind-elixir": "^5.9.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.15.0",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
