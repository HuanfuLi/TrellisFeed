# Copy to .env.local (git-ignored) and fill in real values.
# Vite loads .env.local automatically for both dev and build.

# Base URL of the deployed research-backend Worker.
# Live canonical worker: https://question-trace-research-collector.question-trace.workers.dev
VITE_RESEARCH_API_BASE_URL=

# Bearer credential the app sends to /v1/install/resolve and /v1/ingest.
# Must match RESEARCH_ENROLLMENT_CREDENTIAL configured as a secret on the
# research-backend Worker (see research-backend/.dev.vars.example).
# Minimum 16 characters.
VITE_RESEARCH_ENROLLMENT_CREDENTIAL=
