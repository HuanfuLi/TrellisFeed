{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "frozen-pool.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["manifest", "topics", "posts", "concepts", "claims", "suggestedQuestions", "sourceAssets"],
  "properties": {
    "manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contentPoolVersion", "generatedAt", "preprocessingModelVersions", "rawCandidateCount", "approvedCount", "rejectedCount", "reviewProcedureSummary", "counts", "artifactHashes", "feedOrderPostIds"],
      "properties": {
        "contentPoolVersion": {"type": "string", "minLength": 1, "maxLength": 64},
        "generatedAt": {"type": "string", "format": "date-time"},
        "preprocessingModelVersions": {"type": "array", "items": {"type": "string", "minLength": 1, "maxLength": 200}, "uniqueItems": true, "maxItems": 50},
        "collectorVersions": {"type": "array", "items": {"type": "string", "minLength": 1, "maxLength": 200}, "uniqueItems": true, "maxItems": 50},
        "promptVersions": {"type": "array", "items": {"type": "string", "minLength": 1, "maxLength": 200}, "uniqueItems": true, "maxItems": 50},
        "schemaVersions": {"type": "array", "items": {"type": "string", "minLength": 1, "maxLength": 200}, "uniqueItems": true, "maxItems": 50},
        "rawCandidateCount": {"type": "integer", "minimum": 0},
        "approvedCount": {"type": "integer", "minimum": 0},
        "rejectedCount": {"type": "integer", "minimum": 0},
        "sourceFormatDistribution": {"type":"object","additionalProperties":false,"required":["article","video"],"properties":{"article":{"type":"integer","minimum":0},"video":{"type":"integer","minimum":0}}},
        "stanceDistribution": {"type":"object","additionalProperties":false,"required":["supportive","critical","neutral","mixed"],"properties":{"supportive":{"type":"integer","minimum":0},"critical":{"type":"integer","minimum":0},"neutral":{"type":"integer","minimum":0},"mixed":{"type":"integer","minimum":0}}},
        "reviewProcedureSummary": {"type": "string", "minLength": 1, "maxLength": 4000},
        "counts": {
          "type": "object", "additionalProperties": false,
          "required": ["topics", "posts", "concepts", "claims", "suggestedQuestions", "sourceAssets"],
          "properties": {"topics":{"type":"integer","minimum":0},"posts":{"type":"integer","minimum":0},"concepts":{"type":"integer","minimum":0},"claims":{"type":"integer","minimum":0},"suggestedQuestions":{"type":"integer","minimum":0},"sourceAssets":{"type":"integer","minimum":0}}
        },
        "artifactHashes": {
          "type": "object", "additionalProperties": false,
          "required": ["topics.json", "posts.json", "concepts.json", "claims.json", "suggested_questions.json", "source_assets.json", "sources.json", "global_edges.json", "ranking_features.json"],
          "properties": {"topics.json":{"$ref":"#/$defs/sha256"},"posts.json":{"$ref":"#/$defs/sha256"},"concepts.json":{"$ref":"#/$defs/sha256"},"claims.json":{"$ref":"#/$defs/sha256"},"suggested_questions.json":{"$ref":"#/$defs/sha256"},"source_assets.json":{"$ref":"#/$defs/sha256"},"sources.json":{"$ref":"#/$defs/sha256"},"global_edges.json":{"$ref":"#/$defs/sha256"},"ranking_features.json":{"$ref":"#/$defs/sha256"}}
        },
        "feedOrderPostIds": {"type": "array", "items": {"type": "string", "minLength": 1, "maxLength": 128}, "uniqueItems": true},
        "fixedFilenames": {"type":"array","items":{"type":"string","pattern":"^(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$","maxLength":300},"uniqueItems":true},
        "bundleFileHashes": {"type":"object","propertyNames":{"pattern":"^(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$","maxLength":300},"additionalProperties":{"$ref":"#/$defs/sha256"}}
      }
    },
    "topics": {"type": "array", "items": {"$ref": "topic.schema.json"}},
    "posts": {"type": "array", "items": {"$ref": "post.schema.json"}},
    "concepts": {"type": "array", "items": {"$ref": "concept.schema.json"}},
    "claims": {"type": "array", "items": {"$ref": "claim.schema.json"}},
    "suggestedQuestions": {"type": "array", "items": {"$ref": "suggested-question.schema.json"}},
    "sourceAssets": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["postId", "kind", "sourceUrl", "sha256"],
        "properties": {"postId":{"type":"string","minLength":1,"maxLength":128},"kind":{"enum":["article","video"]},"sourceUrl":{"type":"string","format":"uri","pattern":"^https://","maxLength":2048},"body":{"type":"string","minLength":1,"maxLength":2000000},"videoId":{"type":"string","pattern":"^[A-Za-z0-9_-]{6,20}$"},"digest":{"type":"string","minLength":1,"maxLength":20000},"sha256":{"$ref":"#/$defs/sha256"}},
        "allOf": [{"if":{"properties":{"kind":{"const":"article"}}},"then":{"properties":{"body":{}},"required":["body"]}},{"if":{"properties":{"kind":{"const":"video"}}},"then":{"properties":{"videoId":{},"digest":{}},"required":["videoId","digest"]}}]
      }
    }
  },
  "$defs": {"sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}
}
