{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ranking-features.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["embeddingFingerprint", "posts"],
  "properties": {
    "embeddingFingerprint": {
      "anyOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["provider", "model", "dimensions"],
          "properties": {
            "provider": {"type": "string", "minLength": 1, "maxLength": 100},
            "model": {"type": "string", "minLength": 1, "maxLength": 200},
            "dimensions": {"type": "integer", "minimum": 1, "maximum": 65536}
          }
        }
      ]
    },
    "posts": {
      "type": "array",
      "items": {"$ref": "#/$defs/postRankingFeatures"}
    }
  },
  "allOf": [
    {
      "if": {"properties": {"embeddingFingerprint": {"type": "null"}}},
      "then": {"properties": {"posts": {"items": {"allOf": [{"$ref": "#/$defs/postRankingFeatures"}, {"not": {"required": ["summaryVector"]}}]}}}},
      "else": {"properties": {"posts": {"items": {"allOf": [{"$ref": "#/$defs/postRankingFeatures"}, {"required": ["summaryVector"]}]}}}}
    }
  ],
  "$defs": {
    "score": {"type": "number", "minimum": 0, "maximum": 1},
    "postRankingFeatures": {
      "type": "object",
      "additionalProperties": false,
      "required": ["postId", "topicId", "primaryConceptId", "sourceId", "format", "qualityScore", "educationalValueScore", "interestingnessScore", "difficulty"],
      "properties": {
        "postId": {"type": "string", "minLength": 1, "maxLength": 128},
        "topicId": {"type": "string", "minLength": 1, "maxLength": 128},
        "primaryConceptId": {"type": "string", "minLength": 1, "maxLength": 128},
        "sourceId": {"type": "string", "minLength": 1, "maxLength": 128},
        "format": {"enum": ["video", "article", "social", "other"]},
        "qualityScore": {"$ref": "#/$defs/score"},
        "educationalValueScore": {"$ref": "#/$defs/score"},
        "interestingnessScore": {"$ref": "#/$defs/score"},
        "difficulty": {"$ref": "#/$defs/score"},
        "viewpoint": {"enum": ["supportive", "critical", "neutral", "mixed"]},
        "summaryVector": {"type": "array", "items": {"type": "number"}, "minItems": 1, "maxItems": 65536}
      }
    }
  }
}
