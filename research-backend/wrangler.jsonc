{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "question-trace-research-collector",
  "main": "src/worker.ts",
  "compatibility_date": "2026-07-11",
  "vars": {
    "RESEARCH_ALLOWED_ORIGINS": "capacitor://localhost,http://localhost,http://localhost:5173,https://localhost"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "question_trace",
      "database_id": "4423c511-8a39-411c-983f-f24306084218"
    }
  ]
}
