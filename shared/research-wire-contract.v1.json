{
  "version": "research-ingest-v1",
  "routes": { "enroll": "/v1/install/resolve", "ingest": "/v1/ingest" },
  "authorizationHeader": "Authorization",
  "limits": {
    "maxRequestBytes": 262144,
    "maxRecords": 100,
    "id": 128,
    "accountId": 64,
    "postId": 256,
    "questionId": 256,
    "text": 65536,
    "timestamp": 64
  },
  "forbiddenIdentityFields": ["userId", "condition", "topicId"],
  "recommendation": {
    "kind": "recommendation",
    "strategies": [
      "topic_baseline",
      "quality_baseline",
      "diversity_baseline",
      "continue",
      "deepen",
      "contrast",
      "bridge",
      "echo"
    ],
    "limits": {
      "reasonText": 2048,
      "contributorArrayItems": 64,
      "componentScoreKeys": 32,
      "componentScoreKeyLength": 64
    }
  }
}
